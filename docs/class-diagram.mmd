        +Transfer(ctx, from, to, amount, nonce) error
        +Mint(ctx, to, amount) error
        +GetAccount(ctx, id) (*Account, error)
        +GetAccounts(ctx) ([]*Account, error)
        +AccountCount(ctx) int
    }

    class Account {
        -id ScalegraphId
        -balance float64
        -blockchain IBlockchain
        -publicKey ed25519.PublicKey
        -certificate *x509.Certificate
        -valuestore map~string~string
        -mu RWMutex
        +ID() ScalegraphId
        +Balance() float64
        +Blockchain() IBlockchain
        +PublicKey() ed25519.PublicKey
        +Certificate() *x509.Certificate
        +Debit(amount float64) error
        +Credit(amount float64)
        +GetValue(key string) string
        +SetValue(key, value string)
    }

    class ScalegraphId {
        -data [20]byte
        +FromPublicKey(pubKey) ScalegraphId
        +Random() ScalegraphId
        +String() string
        +Bytes() []byte
        +XorDistance(other ScalegraphId) *big.Int
    }

    class IBlockchain {
        <<interface>>
        +Append(tx *Transaction) error
        +GetLatest() *Block
        +Len() int
        +GetAll() []*Block
    }

    class Blockchain {
        -head *Block
        -tail *Block
        -length int
        -mu RWMutex
        +Append(tx *Transaction) error
        +GetLatest() *Block
        +Len() int
        +GetAll() []*Block
