classDiagram
    class Transport {
        <<interface>>
        +Start(ctx Context) error
        +Stop() error
        +Address() string
        +Type() string
    }

    class RESTTransport {
        -server http.Server
        -client Client
        -address string
        +Start(ctx Context) error
        +Stop() error
        +Address() string
        +Type() string
    }

    class ConnectRPCTransport {
        -httpServer http.Server
        -client Client
        -address string
        -exposeAdmin bool
        -wmSubscriber message.Subscriber
        +Start(ctx Context) error
        +Stop() error
        +Address() string
        +Type() string
    }

    class MCPTransport {
        -server http.Server
        -client Client
        -address string
        +Start(ctx Context) error
        +Stop() error
        +Address() string
        +Type() string
    }

    class TUITransport {
        -client Client
        -model BubbleTeaModel
        +Start(ctx Context) error
        +Stop() error
    }

    class VirtualApp {
        -id ScalegraphId
        -client Client
        -transports []Transport
        -goChannel gochannel.GoChannel
        -ctx Context
        -cancel CancelFunc
        -wg WaitGroup
        +ID() ScalegraphId
        +Client() Client
        +Publisher() message.Publisher
        +Subscriber() message.Subscriber
        +AddTransport(t Transport)
        +Start()
        +Stop()
        +Addresses() map~string~string
    }

    class Client {
        -requestChan chan Request
        -pendingRequests map~string~chan Response
        -mu Mutex
        -timeout Duration
        +CreateAccountWithCredentials(ctx, balance, signedReq) Response
        +GetAccount(ctx, id, signedReq) Account
        +GetAccounts(ctx) []Account
        +TransferSigned(ctx, signedReq) TransferResponse
        +Mint(ctx, to, amount) error
        +AccountCount(ctx) int
        +MintTokenSigned(ctx, signedReq) MintTokenResponse
        +TransferTokenSigned(ctx, signedReq) TransferTokenResponse
        +BurnTokenSigned(ctx, signedReq) BurnTokenResponse
        +AuthorizeTokenTransferSigned(ctx, signedReq) Response
        +UnauthorizeTokenTransferSigned(ctx, signedReq) Response
        +ClawbackTokenSigned(ctx, signedReq) ClawbackTokenResponse
        +LookupTokenSigned(ctx, signedReq) LookupTokenResponse
        +AdminCreateAccount(ctx, balance) CreateAccountResponse
        +AdminMint(ctx, to, amount) error
        -sendRequest(ctx, payload) Response
    }

    class Server {
        -app App
        -registry Registry
        -requestChan chan Request
        -ctx Context
        -cancel CancelFunc
        -wg WaitGroup
        -logger Logger
        -ca CA
        -verifier Verifier
        -handlers map~reflect.Type~handlerFunc
        +Start()
        +Stop()
        +CreateVirtualApp() VirtualApp
        +RequestChannel() chan Request
        +Registry() Registry
        +CA() CA
        -registerHandlers()
        -run()
        -handleRequest(req Request) Response
        -publishEvent(requestPayload, responsePayload)
    }

    class Registry {
        -apps map~ScalegraphId~VirtualApp
        -mu RWMutex
        +Register(app VirtualApp) error
        +Unregister(id ScalegraphId)
        +Get(id ScalegraphId) VirtualApp
        +List() []VirtualApp
        +Count() int
        +GetKClosest(target ScalegraphId, k int) []VirtualApp
    }

    class App {
        -accounts map~ScalegraphId~Account
        -mu RWMutex
        -logger Logger
        +CreateAccount(ctx, balance) Account
        +CreateAccountWithKeys(ctx, pubKey, cert, balance) Account
        +Transfer(ctx, req) TransferResponse
        +Mint(ctx, req) error
        +GetAccount(ctx, req) GetAccountResponse
        +GetAccounts(ctx, req) GetAccountsResponse
        +AccountCount(ctx, req) AccountCountResponse
        +MintToken(ctx, req) MintTokenResponse
        +TransferToken(ctx, req) error
        +BurnToken(ctx, req) error
        +AuthorizeTokenTransfer(ctx, req) error
        +UnauthorizeTokenTransfer(ctx, req) error
        +ClawbackToken(ctx, req) error
        +LookupToken(ctx, req) LookupTokenResponse
    }

    class Account {
        -id ScalegraphId
        -balance float64
        -mbr float64
        -blockchain IBlockchain
        -publicKey ed25519.PublicKey
        -certificate x509.Certificate
        -tokenStore map~string~Token
        -outgoingTxCount uint64
        -mu RWMutex
        +ID() ScalegraphId
        +Balance() float64
        +MBR() float64
        +Blockchain() IBlockchain
        +PublicKey() ed25519.PublicKey
        +Certificate() x509.Certificate
        +GetNonce() uint64
        +GetToken(tokenId string) Token
        +GetTokens() []Token
        +appendTransaction(trx ITransaction) error
        +rollbacklatestTransaction(trx ITransaction) error
    }

    class ScalegraphId {
        -data [20]byte
        +NewScalegraphId() ScalegraphId
        +ScalegraphIdFromPublicKey(pubKey) ScalegraphId
        +String() string
        +Bytes() []byte
        +XorDistance(other ScalegraphId) big.Int
    }

    class IBlockchain {
        <<interface>>
        +Head() Block
        +Tail() Block
        +GetBlocks() []Block
        +Len() int
    }

    class Blockchain {
        -head Block
        -tail Block
        -length int
        -mu RWMutex
        +Head() Block
        +Tail() Block
        +GetBlocks() []Block
        +Len() int
    }

    class Block {
        -transaction ITransaction
        -timestamp time.Time
        -prev Block
        -next Block
        +Transaction() ITransaction
        +Timestamp() time.Time
        +PrevBlock() Block
    }

    class ITransaction {
        <<interface>>
        +ID() ScalegraphId
        +Type() TransactionType
        +Sender() Account
        +Receiver() Account
    }

    class TransferTransaction {
        -id ScalegraphId
        -sender Account
        -receiver Account
        -amount float64
        +Amount() float64
    }

    class MintTransaction {
        -id ScalegraphId
        -receiver Account
        -amount float64
        +Amount() float64
    }

    class BurnTransaction {
        -id ScalegraphId
        -receiver Account
        -amount float64
        +Amount() float64
    }

    class MintTokenTransaction {
        -id ScalegraphId
        -receiver Account
        -token Token
        +Token() Token
    }

    class TransferTokenTransaction {
        -id ScalegraphId
        -sender Account
        -receiver Account
        -token Token
        +Token() Token
    }

    class BurnTokenTransaction {
        -id ScalegraphId
        -accountID Account
        -tokenID string
        +TokenID() string
    }

    class AuthorizeTokenTransferTransaction {
        -id ScalegraphId
        -account Account
        -tokenId string
        +TokenId() string
    }

    class UnauthorizeTokenTransferTransaction {
        -id ScalegraphId
        -account Account
        -tokenId string
        +TokenId() string
    }

    class ClawbackTokenTransaction {
        -id ScalegraphId
        -from Account
        -to Account
        -token Token
        +Token() Token
    }

    class Token {
        -value string
        -signature Signature
        -clawbackAddress ScalegraphId
        -nonce int64
        +ID() string
        +Value() string
        +Signature() Signature
        +ClawbackAddress() ScalegraphId
        +Nonce() int64
        +Equal(other IToken) bool
    }

    class CA {
        -privateKey ed25519.PrivateKey
        -publicKey ed25519.PublicKey
        -certificate x509.Certificate
        +CreateAccountCredentials() KeyPair
        +IssueCertificate(accountID, pubKey) x509.Certificate
        +VerifyCertificate(cert) error
        +NewVerifier() Verifier
        +PublicKey() ed25519.PublicKey
    }

    class Verifier {
        -caCert x509.Certificate
        -timestampWindow Duration
        +VerifyCertificate(cert) error
        +VerifySignature(data, sig, pubKey) error
        +VerifyTimestamp(sig) error
        +VerifyEnvelope(envelope) PublicKey
    }

    class Verifiable {
        <<interface>>
        +RequiresSignature() bool
        +Verify(verifier Verifier, caPublicKey ed25519.PublicKey) error
    }

    class SignedEnvelope~T~ {
        +Payload T
        +Signature Signature
        +Certificate string
    }

    Transport <|.. RESTTransport
    Transport <|.. ConnectRPCTransport
    Transport <|.. MCPTransport
    Transport <|.. TUITransport

    VirtualApp o-- Transport : contains multiple
    VirtualApp *-- Client : owns
    VirtualApp -- ScalegraphId : has

    Client --> Server : sends requests via channel

    Server *-- App : owns
    Server *-- Registry : owns
    Server *-- CA : owns
    Server *-- Verifier : owns
    Server -- Client : receives from

    CA --> Verifier : creates

    Registry o-- VirtualApp : manages

    App o-- Account : manages multiple

    Account *-- ScalegraphId : has
    Account *-- IBlockchain : owns
    Account o-- Token : tokenStore

    IBlockchain <|.. Blockchain
    Blockchain o-- Block : linked list
    Block *-- ITransaction : contains

    ITransaction <|.. TransferTransaction
    ITransaction <|.. MintTransaction
    ITransaction <|.. BurnTransaction
    ITransaction <|.. MintTokenTransaction
    ITransaction <|.. TransferTokenTransaction
    ITransaction <|.. BurnTokenTransaction
    ITransaction <|.. AuthorizeTokenTransferTransaction
    ITransaction <|.. UnauthorizeTokenTransferTransaction
    ITransaction <|.. ClawbackTokenTransaction
    
%% ---------------------------------------------------------------------------
%% Overview
%% ---------------------------------------------------------------------------
%% This diagram shows the object-oriented structure of the SG Emulator.
%% 
%% Key Design Patterns
%% 
%% 1. Interface Segregation
%%    - Transport interface: REST, ConnectRPC, MCP, TUI implementations
%%    - IBlockchain interface implemented by Blockchain
%%    - ITransaction interface with nine concrete transaction types
%%    - Verifiable interface auto-checked by the server before dispatching
%% 
%% 2. Composition Over Inheritance
%%    - VirtualApp contains multiple Transports and a Watermill GoChannel
%%    - Server owns App, Registry, CA, and Verifier
%%    - Account owns IBlockchain, tokenStore, and cryptographic credentials
%% 
%% 3. Thread-Safe Design
%%    - RWMutex in App, Account, Blockchain, Registry, Client
%%    - Channel-based communication between Client and Server
%%    - Buffered requestChan (size 1000) decouples transports from server loop
%% 
%% 4. Domain Model
%%    - ScalegraphId: 160-bit identifier (DHT-compatible, ed25519 public key hash)
%%    - Account: balance, MBR, per-account blockchain, tokenStore, crypto keys
%%    - Token: signed asset with clawback support and MBR-backed ownership slots
%%    - Blockchain: per-account immutable linked list of ITransaction blocks
%%    - SignedEnvelope[T]: payload + ed25519 signature + X.509 certificate
%% 
%% 5. Event System
%%    - After each successful request, Server.publishEvent() publishes a
%%      protobuf event to every VirtualApp GoChannel on topic events.<accountID>
%%    - ConnectRPC transport subscribes and streams events to clients
%% 
