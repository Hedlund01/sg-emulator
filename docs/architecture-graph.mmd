%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#dbeafe', 'primaryBorderColor': '#3b82f6', 'primaryTextColor': '#1e3a5f', 'lineColor': '#374151', 'textColor': '#111827', 'background': '#ffffff'}}}%%
graph TB
    subgraph "Transport Layer"
        REST[REST Transport<br/>Port 8080+<br/>HTTP/Swagger]
        CONNECTRPC[ConnectRPC Transport<br/>Configurable port<br/>HTTP/1.1 + HTTP/2]
        MCP[MCP Transport<br/>Configurable port<br/>HTTP/SSE for LLMs]
        TUI[TUI Transport<br/>Terminal UI<br/>Bubble Tea]
    end

    subgraph "Virtual Apps Layer"
        direction LR
        VA[VirtualApp ×N<br/>ID: ScalegraphId<br/>Multiple Transports]
        CLIENT[Client<br/>Request/Response<br/>Channels]
        GOCHANNEL[GoChannel<br/>Watermill pub/sub<br/>Events per Account]
        VA -.->|uses| CLIENT
        VA -->|owns| GOCHANNEL
    end

    subgraph "Server Layer"
        REGISTRY[Registry<br/>VirtualApp Management<br/>DHT Routing]
        REQCHAN[requestChan<br/>Buffered Channel<br/>Size: 1000]
        SERVER[Server<br/>Event Loop<br/>Request Processing]
        CA[Certificate Authority<br/>ed25519 Keys<br/>Account Credentials]
        VERIFIER[Verifier<br/>Cert Chain + Sig<br/>Timestamp Checks]
    end

    subgraph "App Layer - Business Logic"
        APP[App<br/>Thread-Safe<br/>RWMutex]
        ACCOUNTS[accounts map<br/>ScalegraphId → Account]
    end

    subgraph "Scalegraph Layer - Data Model"
        ACC1[Account #1<br/>ID / Balance / MBR<br/>outgoingTxCount / tokenStore]
        ACC2[Account #2<br/>ID / Balance / MBR<br/>outgoingTxCount / tokenStore]
        ACC3[Account #N<br/>ID / Balance / MBR<br/>outgoingTxCount / tokenStore]

        TOKEN[Token<br/>value / nonce<br/>signature / clawbackAddress]

        BC1[Blockchain #1<br/>Linked List of Blocks]
        BC2[Blockchain #2<br/>Linked List of Blocks]
        BC3[Blockchain #N<br/>Linked List of Blocks]

        TX[ITransaction<br/>Transfer · Mint · Burn<br/>MintToken · TransferToken<br/>BurnToken · Clawback]
    end

    REST -->|attached to| VA
    CONNECTRPC -->|attached to| VA
    MCP -->|attached to| VA
    TUI -->|attached to| VA

    CLIENT -->|sends Request| REQCHAN
    REQCHAN -->|processes| SERVER
    SERVER -->|manages| REGISTRY
    SERVER -->|uses| CA
    CA -->|creates| VERIFIER
    SERVER -.->|auto-verifies via| VERIFIER
    SERVER -.->|sends Response| CLIENT
    SERVER -->|publishes events to| GOCHANNEL
    REGISTRY -->|tracks| VA
    SERVER -->|delegates to| APP
    APP -->|manages| ACCOUNTS

    ACCOUNTS -->|contains| ACC1
    ACCOUNTS -->|contains| ACC2
    ACCOUNTS -->|contains| ACC3

    ACC1 -->|has| BC1
    ACC2 -->|has| BC2
    ACC3 -->|has| BC3

    ACC1 -.->|tokenStore| TOKEN
    ACC2 -.->|tokenStore| TOKEN
    ACC3 -.->|tokenStore| TOKEN

    BC1 -->|stores| TX
    BC2 -->|stores| TX
    BC3 -->|stores| TX

